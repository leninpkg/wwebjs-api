# WhatsApp Configuration
INSTANCE_NAME=develop
CLIENT_ID=1
SESSION_ID=develop

# Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=wwebjs-api

# API Configuration
PORT=727

# Files API to upload media files
FILES_API_URL=https://inpulse.infotecrs.inf.br

# Event Endpoints (comma-separated)
WPP_EVENT_ENDPOINTS=http://localhost:8005/api/whatsapp/remote/:clientId/event"

# Optional: Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# Optional: Node Environment
NODE_ENV=development

# Humanization Settings - Typing Simulation
# Delay per character in milliseconds (higher = slower typing)
TYPING_MIN_DELAY_PER_CHAR=30  # Fast typing (30ms per character)
TYPING_MAX_DELAY_PER_CHAR=60  # Slow typing (60ms per character)

# Humanization Settings - Message Delay & Rate Limiting
# Controls how the message queue (Bottleneck) spaces out messages
MESSAGE_MIN_DELAY=3000  # Minimum delay between messages (3 seconds)
MESSAGE_MAX_DELAY=8000  # Maximum random delay after message (8 seconds)
WA_MESSAGES_PER_HOUR=300  # Maximum messages per hour to prevent WhatsApp blocks