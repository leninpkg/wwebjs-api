# WhatsApp Configuration
INSTANCE_NAME=develop
CLIENT_ID=1
SESSION_ID=develop

# Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=wwebjs-api

# API Configuration
PORT=727

# Files API to upload media files
FILES_API_URL=https://inpulse.infotecrs.inf.br

# Event Endpoints (comma-separated)
WPP_EVENT_ENDPOINTS=http://localhost:8005/api/whatsapp/remote/:clientId/event"

# Optional: Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# Optional: Node Environment
NODE_ENV=development