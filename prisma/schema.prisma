generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Session {
  id          String          @id
  instance    String          @map("instance")
  apiType     WhatsappApiType @map("api_type")
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("sessions")
}

model BaileysAuth {
  sessionId String   @map("session_id")
  key       String   @map("key") @db.VarChar(255)
  value     Json     @map("value")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sessionId, key], name: "uq_baileys_data_session_id_key")
  @@index([sessionId], name: "idx_baileys_data_session_id")
  @@index([key], name: "idx_baileys_data_key")
  @@map("baileys_auth")
}

model RawGroupMetadata {
  id        String @id
  remoteJid String @map("remote_jid")
  sessionId String @map("session_id")

  instance  String
  metadata  Json     @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([remoteJid], name: "idx_group_metadata_remote_jid")
  @@index([sessionId], name: "idx_group_metadata_session_id")
  @@index([instance], name: "idx_group_metadata_instance")
  @@map("group_metadata")
}

model RawMessage {
  id          String   @id
  sessionId   String   @map("session_id")
  remoteJid   String   @map("remote_jid")
  instance    String
  timestamp   String   @db.VarChar(20)
  keyData     Json     @map("key_data")
  messageData Json     @map("message_data")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parsedMessage     InpulseMessage?
  messageSyncStatus MessageProcessingStatus?
  file              RawMessageFile?

  @@map("raw_messages")
}

model RawMessageFile {
  id        String   @id
  messageId String   @unique @map("message_id")
  inpulseId Int?     @unique @map("inpulse_id")
  fileName  String   @map("file_name") @db.Text
  fileType  String   @map("file_type")
  fileSize  Int?     @map("file_size")
  filePath  String   @map("file_path") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  message RawMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("raw_message_files")
}

model RawContact {
  id           String   @id
  sessionId    String   @map("session_id")
  instance     String
  lid          String?  @db.VarChar(255)
  phoneNumber  String?  @map("phone_number") @db.VarChar(50)
  name         String?  @db.VarChar(255)
  notify       String?  @db.VarChar(255)
  verifiedName String?  @db.VarChar(255)
  imgUrl       String?  @map("img_url") @db.Text
  status       String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("raw_contacts")
}

model InpulseMessage {
  messageId   String               @map("message_id")
  sessionId   String               @map("session_id")
  instance    String               @map("instance")
  from        String
  to          String
  type        InpulseMessageType
  quotedId    String?              @map("quoted_id")
  body        String?              @db.Text
  timestamp   String               @db.VarChar(20)
  sentAt      DateTime             @map("sent_at")
  status      InpulseMessageStatus
  fileId      String?              @map("file_id")
  fileName    String?              @map("file_name") @db.Text
  fileType    String?              @map("file_type")
  fileSize    Int?                 @map("file_size")
  isForwarded Boolean              @map("is_forwarded")
  isEdited    Boolean              @map("is_edited")

  message RawMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId], name: "uq_inpulse_messages_message_id")
  @@index([sessionId], name: "idx_inpulse_messages_session_id")
  @@index([from], name: "idx_inpulse_messages_from")
  @@map("inpulse_messages")
}

model MessageProcessingStatus {
  messageId String @map("message_id")
  sessionId String @map("session_id")

  isParsed  Boolean @map("is_parsed")
  isSaved   Boolean @map("is_saved")
  isUpdated Boolean @map("is_updated")

  message RawMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId], name: "uq_message_processing_status_message_id")
  @@map("message_processing_status")
}

model Log {
  id            String   @id @default(uuid())
  level         LogLevel
  emittedBy     String?  @map("emitted_by")
  operationName String?  @map("operation_name")
  correlationId String?  @map("correlation_id")
  message       String   @db.Text
  metadata      Json?
  sessionId     String?  @map("session_id")
  instance      String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([level], name: "idx_logs_level")
  @@index([correlationId], name: "idx_logs_correlation_id")
  @@index([operationName], name: "idx_logs_operation_name")
  @@index([sessionId], name: "idx_logs_session_id")
  @@index([createdAt], name: "idx_logs_created_at")
  @@map("logs")
}

enum LogLevel {
  trace
  debug
  info
  warn
  error
  fatal
}

enum InpulseMessageStatus {
  PENDING
  SENT
  RECEIVED
  READ
  DOWNLOADED
  ERROR
  REVOKED
}

enum InpulseMessageType {
  text
  ptt
  image
  video
  audio
  document
  sticker
  list
  location
  contact
  multi_contact
  unsupported
}

enum WhatsappApiType {
  baileys
  wwebjs
  gupshup
  waba
}
