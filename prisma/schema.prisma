generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Session {
  id          String          @id
  instance    String          @map("instance")
  apiType     WhatsappApiType @map("api_type")
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("sessions")
}

model BaileysAuth {
  sessionId String   @map("session_id")
  key       String   @map("key") @db.VarChar(255)
  value     String   @map("value")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sessionId, key], name: "uq_baileys_data_session_id_key")
  @@index([sessionId], name: "idx_baileys_data_session_id")
  @@index([key], name: "idx_baileys_data_key")
  @@map("baileys_auth")
}

model RawGroupMetadata {
  id        String @id
  remoteJid String @map("remote_jid")

  instance  String
  sessionId String   @map("session_id")
  metadata  Json     @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("group_metadata")
}

model RawMessage {
  id          String   @id
  sessionId   String   @map("session_id")
  remoteJid   String   @map("remote_jid")
  instance    String
  timestamp   String   @db.VarChar(20)
  keyData     Json     @map("key_data")
  messageData Json     @map("message_data")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parsedMessage     InpulseMessage?
  messageSyncStatus MessageProcessingStatus?

  @@map("raw_messages")
}

model InpulseMessage {
  messageId   String               @map("message_id")
  sessionId   String               @map("session_id")
  instance    String               @map("instance")
  from        String
  to          String
  type        InpulseMessageType
  quotedId    String?              @map("quoted_id")
  body        String?              @db.Text
  timestamp   String               @db.VarChar(20)
  sentAt      DateTime             @map("sent_at")
  status      InpulseMessageStatus
  fileId      String?              @map("file_id")
  fileName    String?              @map("file_name") @db.Text
  fileType    String?              @map("file_type")
  fileSize    Int?                 @map("file_size")
  isForwarded Boolean              @map("is_forwarded")
  isEdited    Boolean              @map("is_edited")

  message RawMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId], name: "uq_parsed_messages_message_id")
  @@index([sessionId], name: "idx_parsed_messages_session_id")
  @@index([from], name: "idx_parsed_messages_from")
  @@map("parsed_messages")
}

model MessageProcessingStatus {
  messageId String @map("message_id")
  sessionId String @map("session_id")

  isParsed  Boolean @map("is_parsed")
  isSaved   Boolean @map("is_saved")
  isUpdated Boolean @map("is_updated")

  message RawMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId], name: "uq_message_processing_status_message_id")
  @@map("message_processing_status")
}

enum InpulseMessageStatus {
  PENDING
  SENT
  RECEIVED
  READ
  DOWNLOADED
  ERROR
  REVOKED
}

enum InpulseMessageType {
  text
  ptt
  image
  video
  audio
  document
  sticker
  list
  location
  contact
  multi_contact
  unsupported
}

enum WhatsappApiType {
  baileys
  wwebjs
  gupshup
  waba
}
