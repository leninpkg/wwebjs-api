generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Session {
  id          String          @id
  instance    String          @map("instance")
  apiType     WhatsappApiType @map("api_type")
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("sessions")
}

model BaileysAuth {
  sessionId String   @map("session_id")
  key       String   @map("key") @db.VarChar(255)
  value     String   @map("value") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sessionId, key], name: "uq_baileys_data_session_id_key")
  @@index([sessionId], name: "idx_baileys_data_session_id")
  @@index([key], name: "idx_baileys_data_key")
  @@map("baileys_auth")
}

model RawGroup {
  sessionId String @map("session_id")
  instance  String

  id        String   @id
  name      String?  @db.VarChar(255)
  groupData String   @map("group_data") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([instance], name: "idx_raw_groups_instance")
  @@map("raw_groups")
}

model RawMessage {
  id          String   @id
  sessionId   String   @map("session_id")
  remoteJid   String   @map("remote_jid")
  instance    String
  timestamp   String   @db.VarChar(20)
  keyData     String   @map("key_data") @db.Text
  messageData String   @map("message_data") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  inpulseMessage      InpulseMessage?
  messageSyncStatuses MessageProcessingStatus[]
  file                RawMessageFile?

  @@index([instance], name: "idx_raw_messages_instance")
  @@index([remoteJid], name: "idx_raw_messages_remote_jid")
  @@map("raw_messages")
}

model RawMessageFile {
  id        String   @id @default(nanoid())
  messageId String   @unique @map("message_id")
  inpulseId Int      @unique @map("inpulse_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  message RawMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId], name: "idx_raw_message_files_message_id")
  @@map("raw_message_files")
}

model RawContact {
  id           String   @id
  sessionId    String   @map("session_id")
  instance     String
  lid          String?  @db.VarChar(255)
  phoneNumber  String?  @map("phone_number") @db.VarChar(50)
  name         String?  @db.VarChar(255)
  notify       String?  @db.VarChar(255)
  verifiedName String?  @db.VarChar(255)
  imgUrl       String?  @map("img_url") @db.Text
  status       String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([instance], name: "idx_raw_contacts_instance")
  @@index([phoneNumber], name: "idx_raw_contacts_phone_number")
  @@index([lid], name: "idx_raw_contacts_lid")
  @@map("raw_contacts")
}

model InpulseMessage {
  messageId   String               @map("message_id")
  sessionId   String               @map("session_id")
  instance    String               @map("instance")
  from        String
  to          String
  type        InpulseMessageType
  quotedId    String?              @map("quoted_id")
  body        String?              @db.Text
  timestamp   String               @db.VarChar(20)
  sentAt      DateTime             @map("sent_at")
  status      InpulseMessageStatus
  fileId      Int?                 @map("file_id")
  fileName    String?              @map("file_name") @db.Text
  fileType    String?              @map("file_type")
  fileSize    String?                 @map("file_size")
  isForwarded Boolean              @default(false) @map("is_forwarded")
  isEdited    Boolean              @default(false) @map("is_edited")
  clientId    Int                  @map("client_id")

  message RawMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId], name: "uq_inpulse_messages_message_id")
  @@index([instance], name: "idx_inpulse_messages_instance")
  @@index([from], name: "idx_inpulse_messages_from")
  @@index([to], name: "idx_inpulse_messages_to")
  @@map("inpulse_messages")
}

model MessageProcessingStatus {
  id             String                 @id @default(nanoid())
  messageId      String                 @map("message_id")
  sessionId      String                 @map("session_id")
  processingType MessageProcessingType  @map("processing_type")
  status         MessageProcessingState @default(PENDING)
  attempts       Int                    @default(0)
  nextAttemptAt  DateTime?              @map("next_attempt_at")
  processingAt   DateTime?              @map("processing_at")
  processedAt    DateTime?              @map("processed_at")
  lastError      String?                @map("last_error") @db.Text
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  message RawMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, processingType], name: "uq_message_processing_status_message_id_type")
  @@index([sessionId, status], name: "idx_message_processing_status_session_status")
  @@index([status, nextAttemptAt], name: "idx_message_processing_status_queue")
  @@map("message_processing_status")
}

model Log {
  id            String   @id @default(uuid())
  level         LogLevel
  emittedBy     String?  @map("emitted_by")
  operationName String?  @map("operation_name")
  correlationId String?  @map("correlation_id")
  message       String   @db.Text
  metadata      String?  @db.Text
  sessionId     String?  @map("session_id")
  instance      String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([level], name: "idx_logs_level")
  @@index([correlationId], name: "idx_logs_correlation_id")
  @@index([operationName], name: "idx_logs_operation_name")
  @@index([sessionId], name: "idx_logs_session_id")
  @@index([createdAt], name: "idx_logs_created_at")
  @@map("logs")
}

enum LogLevel {
  trace
  debug
  info
  warn
  error
  fatal
}

enum InpulseMessageStatus {
  PENDING
  SENT
  RECEIVED
  READ
  DOWNLOADED
  ERROR
  REVOKED
}

enum InpulseMessageType {
  text
  ptt
  image
  video
  audio
  document
  sticker
  list
  location
  contact
  multi_contact
  unsupported
}

enum WhatsappApiType {
  baileys
  wwebjs
  gupshup
  waba
}

enum MessageProcessingState {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum MessageProcessingType {
  RECEIVE
  EDIT
}
